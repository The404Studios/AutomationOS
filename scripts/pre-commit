#!/bin/bash
#
# AutomationOS Pre-Commit Hook
# ============================
#
# This hook is executed before git commit.
# It ensures code quality by:
#   1. Auto-formatting all staged C files with clang-format
#   2. Running static analysis with clang-tidy
#   3. Checking for common issues (trailing whitespace, tabs/spaces, etc.)
#
# Installation: ./scripts/install-hooks.sh or make install-hooks

set -e

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

echo -e "${BLUE}[Pre-Commit]${NC} Running code quality checks..."

# Get the project root directory
PROJECT_ROOT="$(git rev-parse --show-toplevel)"
cd "$PROJECT_ROOT"

# Check if clang-format is available
if ! command -v clang-format &> /dev/null; then
    echo -e "${YELLOW}[Warning]${NC} clang-format not found. Skipping formatting."
    SKIP_FORMAT=1
else
    SKIP_FORMAT=0
fi

# Check if clang-tidy is available
if ! command -v clang-tidy &> /dev/null; then
    echo -e "${YELLOW}[Warning]${NC} clang-tidy not found. Skipping static analysis."
    SKIP_TIDY=1
else
    SKIP_TIDY=0
fi

# Get list of staged C/H files
STAGED_C_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(c|h)$' || true)
STAGED_ASM_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.asm$' || true)

if [ -z "$STAGED_C_FILES" ] && [ -z "$STAGED_ASM_FILES" ]; then
    echo -e "${GREEN}[Pre-Commit]${NC} No source files staged. Skipping checks."
    exit 0
fi

echo -e "${GREEN}[Pre-Commit]${NC} Found $(echo "$STAGED_C_FILES" | wc -l) staged C/H files"

FAILED=0

# Step 1: Auto-format staged C files
if [ $SKIP_FORMAT -eq 0 ] && [ -n "$STAGED_C_FILES" ]; then
    echo -e "\n${BLUE}[1/6] Auto-formatting code with clang-format...${NC}"

    for FILE in $STAGED_C_FILES; do
        if [ -f "$FILE" ]; then
            # Format the file in-place
            clang-format -i -style=file "$FILE"

            # Check if file was modified
            if ! git diff --quiet "$FILE"; then
                echo -e "${YELLOW}  ✓ Formatted:${NC} $FILE"
                # Re-stage the formatted file
                git add "$FILE"
            else
                echo -e "${GREEN}  ✓ Already formatted:${NC} $FILE"
            fi
        fi
    done
else
    echo -e "\n${YELLOW}[1/6] Skipping clang-format (not available)${NC}"
fi

# Step 2: Check for trailing whitespace
echo -e "\n${BLUE}[2/6] Checking for trailing whitespace...${NC}"
for FILE in $STAGED_C_FILES $STAGED_ASM_FILES; do
    if [ -f "$FILE" ]; then
        if grep -n '[[:space:]]$' "$FILE" > /dev/null; then
            echo -e "${YELLOW}  Fixing trailing whitespace:${NC} $FILE"
            # Auto-remove trailing whitespace
            sed -i 's/[[:space:]]*$//' "$FILE"
            git add "$FILE"
        fi
    fi
done
echo -e "${GREEN}✓ No trailing whitespace${NC}"

# Step 3: Check for tabs vs spaces (should be all tabs for indentation)
echo -e "\n${BLUE}[3/6] Checking indentation (tabs vs spaces)...${NC}"
for FILE in $STAGED_C_FILES; do
    if [ -f "$FILE" ]; then
        # Check for lines with leading spaces (should be tabs)
        if grep -qn '^    ' "$FILE"; then
            echo -e "${RED}  ✗ Spaces used for indentation:${NC} $FILE"
            echo -e "    ${YELLOW}Use tabs, not spaces. Run 'make format' to fix.${NC}"
            FAILED=1
        fi
    fi
done
if [ $FAILED -eq 0 ]; then
    echo -e "${GREEN}✓ Indentation OK (tabs used)${NC}"
fi

# Step 4: Run clang-tidy on staged C files
if [ $SKIP_TIDY -eq 0 ] && [ -n "$STAGED_C_FILES" ]; then
    echo -e "\n${BLUE}[4/6] Running static analysis with clang-tidy...${NC}"

    TIDY_ERRORS=0

    for FILE in $STAGED_C_FILES; do
        if [ -f "$FILE" ]; then
            # Run clang-tidy
            TIDY_OUTPUT=$(clang-tidy "$FILE" -- -I"$PROJECT_ROOT/kernel/include" 2>&1 || true)

            if echo "$TIDY_OUTPUT" | grep -q "warning:"; then
                echo -e "${RED}  ✗ Warnings in:${NC} $FILE"
                echo "$TIDY_OUTPUT" | grep "warning:" | head -3
                TIDY_ERRORS=$((TIDY_ERRORS + 1))
            else
                echo -e "${GREEN}  ✓ Clean:${NC} $FILE"
            fi
        fi
    done

    if [ $TIDY_ERRORS -gt 0 ]; then
        echo -e "\n${RED}[Pre-Commit]${NC} clang-tidy found warnings in $TIDY_ERRORS files"
        echo -e "${YELLOW}Run 'make lint' to see full details${NC}"
        echo -e "${YELLOW}To commit anyway: git commit --no-verify${NC}"
        FAILED=1
    else
        echo -e "${GREEN}✓ Static analysis passed${NC}"
    fi
else
    echo -e "\n${YELLOW}[4/6] Skipping clang-tidy (not available)${NC}"
fi

# Step 5: Check for debugging leftovers
echo -e "\n${BLUE}[5/6] Checking for debug markers...${NC}"
DEBUG_FOUND=0
for FILE in $STAGED_C_FILES; do
    if [ -f "$FILE" ]; then
        MARKERS=$(grep -n 'XXX\|HACK\|TEMPORARY\|DEBUG.*printf' "$FILE" || true)
        if [ -n "$MARKERS" ]; then
            echo -e "${YELLOW}  ⚠ Debug markers in:${NC} $FILE"
            echo "$MARKERS" | head -3
            DEBUG_FOUND=1
        fi
    fi
done
if [ $DEBUG_FOUND -eq 0 ]; then
    echo -e "${GREEN}✓ No debug markers found${NC}"
fi

# Step 6: Check commit message format
echo -e "\n${BLUE}[6/6] Checking commit message format...${NC}"
if [ -f "$PROJECT_ROOT/.git/COMMIT_EDITMSG" ]; then
    COMMIT_MSG=$(head -1 "$PROJECT_ROOT/.git/COMMIT_EDITMSG")
    MSG_LEN=${#COMMIT_MSG}

    if [ $MSG_LEN -lt 10 ]; then
        echo -e "${RED}  ✗ Commit message too short (< 10 chars)${NC}"
        FAILED=1
    elif [ $MSG_LEN -gt 72 ]; then
        echo -e "${YELLOW}  ⚠ Commit message > 72 chars (consider shortening)${NC}"
    else
        echo -e "${GREEN}✓ Commit message format OK${NC}"
    fi
fi

# Summary
echo ""
echo "=========================================="
if [ $FAILED -ne 0 ]; then
    echo -e "${RED}Pre-commit checks FAILED${NC}"
    echo -e "Fix the issues above or use: ${YELLOW}git commit --no-verify${NC}"
    exit 1
else
    echo -e "${GREEN}All pre-commit checks PASSED ✓${NC}"
    echo -e "${GREEN}Proceeding with commit...${NC}"
    exit 0
fi
